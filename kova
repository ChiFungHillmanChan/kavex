#!/bin/bash
# kova — Kova Protocol CLI
# Run the Kova loop, check status, manage hooks — all from terminal.
#
# Usage:
#   kova loop <prd-file> [--silent] [--dry-run] [--no-commit]
#   kova help
#   kova status
#   kova activate / deactivate
#   kova install [--dry-run]

set -e

# Colors (disable if not a terminal)
if [ -t 1 ]; then
  BOLD='\033[1m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  RED='\033[0;31m'
  CYAN='\033[0;36m'
  DIM='\033[0;2m'
  RESET='\033[0m'
else
  BOLD='' GREEN='' YELLOW='' RED='' CYAN='' DIM='' RESET=''
fi

# Find project root (walk up until .claude/ or .git found)
find_project_root() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/.claude" ] || [ -d "$dir/.git" ]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  echo "$PWD"
}

PROJECT_ROOT="$(find_project_root)"
SETTINGS_LOCAL="$PROJECT_ROOT/.claude/settings.local.json"
SETTINGS="$PROJECT_ROOT/.claude/settings.json"

